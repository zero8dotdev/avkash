# Copy to `.env` for docker compose overrides (compose auto-reads `.env`).
# Defaults live in docker-compose.yml; set these to change them.

# Postgres
POSTGRES_USER=avkash
POSTGRES_PASSWORD=avkash
POSTGRES_DB=avkash

# API / Better Auth
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3001
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Used by `pnpm --filter @avkash/db db:push` from the HOST (note: localhost,
# not the `postgres` service name, since you run it outside the network):
# DATABASE_URL=postgres://avkash:avkash@localhost:5432/avkash
