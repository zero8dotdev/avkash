{
  "name": "@avkash/web",
  "version": "0.0.0",
  "private": true,
  "description": "App: SvelteKit frontend for Avkash v2. Imports @avkash/api types for the Hono client; no db/domain packages.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf .turbo node_modules .svelte-kit build"
  },
  "dependencies": {
    "@avkash/api": "workspace:*",
    "better-auth": "^1.2.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@avkash/eslint-config": "workspace:*",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
