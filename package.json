{
  "name": "avkash",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "email:dev": "pnpm --filter @avkash/emails dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "clean": "turbo run clean",
    "authz:backfill": "bun packages/authz-sync/src/backfill.ts",
    "demo:seed": "bun scripts/seed-meridian.ts",
    "demo:seed:india": "bun scripts/seed-india.ts",
    "demo:smoke": "bun scripts/demo-smoke.ts",
    "demo:seed:credentials": "bun scripts/seed-credentials.ts"
  },
  "devDependencies": {
    "@avkash/eslint-config": "workspace:*",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0",
    "@types/node": "^20.17.27",
    "eslint": "^9.17.0",
    "knip": "^5.46.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@avkash/attendance": "workspace:*",
    "@avkash/authz": "workspace:*",
    "@avkash/authz-sync": "workspace:*",
    "@avkash/db": "workspace:*",
    "@avkash/holidays": "workspace:*",
    "@avkash/leave": "workspace:*",
    "@avkash/org": "workspace:*",
    "@avkash/shared": "workspace:*",
    "@avkash/users": "workspace:*",
    "drizzle-orm": "^0.38.4"
  }
}
