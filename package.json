{
  "name": "avkash",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "email:dev": "pnpm --filter @avkash/emails dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "clean": "turbo run clean",
    "authz:backfill": "bun packages/authz-sync/src/backfill.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@avkash/eslint-config": "workspace:*",
    "@commitlint/types": "^19.5.0",
    "@types/node": "^20.17.27",
    "eslint": "^9.17.0",
    "knip": "^5.46.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.8.2"
  }
}
