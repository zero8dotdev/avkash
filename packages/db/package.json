{
  "name": "@avkash/db",
  "version": "0.0.0",
  "private": true,
  "description": "Foundation: Drizzle schema (ALL tables), client, migrations. Single source of schema truth.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "dependencies": {
    "@avkash/shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@avkash/tsconfig": "workspace:*",
    "@avkash/eslint-config": "workspace:*",
    "@types/node": "^20.17.27",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.8.2"
  }
}
